{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "vite:env": "LC_ALL=de_DE.UTF-8 TZ=UTC vite",
    "vitest:env": "LC_ALL=de_DE.UTF-8 TZ=UTC vitest",
    "dev": "yarn vite:env",
    "build": "run-p type-check \"build-only -- {@}\" -- ",
    "preview": "yarn vite:env preview",
    "test": "yarn vitest:env",
    "test:ui": "yarn vitest:env --ui",
    "coverage": "yarn vitest:env run --coverage",
    "build-only": "yarn vite:env build",
    "type-check": "vue-tsc --build --declaration --emitDeclarationOnly tsconfig.json",
    "type-build": "vue-tsc --build --force tsconfig.json",
    "lint:check": "eslint --config eslint.config.ts",
    "lint": "yarn lint:check --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "upgrade:all": "yarn up \"*\"",
    "clean": "rm -rf coverage dist html lib cypress.config.js cypress.config.d.ts tsconfig.node.tsbuildinfo tsconfig.tsbuildinfo vite.config.js vite.config.d.ts stats.html",
    "clean:all": "yarn clean && rm -rf node_modules .million && yarn cache clean",
    "openapi:generate": "TS_POST_PROCESS_FILE=\"./openapi-post-process.sh\" && openapi-generator-cli generate && ./openapi-post-process.sh ./src/api/generated/runtime.ts && yarn lint"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@ant-design/icons-vue": "^7.0.1",
    "@azure/msal-browser": "^5.17.1",
    "@heroicons/vue": "^2.2.0",
    "@vueuse/core": "^14.3.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "js-cookie": "^3.0.8",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "nanoid": "^6.0.0",
    "pinia": "^3.0.4",
    "pinia-generic": "^0.2.3",
    "splitpanes": "^4.1.2",
    "vue": "^3.5.40",
    "vue-auth3": "^1.1.2",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.40.0",
    "@pinia/testing": "^1.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__js": "^9.14.0",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/splitpanes": "^2.2.6",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/cli-plugin-typescript": "^5.0.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "antdv-component-resolver": "^1.0.8",
    "cypress": "^15.19.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-gitlab": "^7.2.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.10.0",
    "happy-dom": "^20.11.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "sass": "^1.101.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7",
    "yarn-run-all": "^3.1.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": "eslint --fix",
    "**/*": "prettier -w -u"
  }
}
